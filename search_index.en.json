opment Engineer in Amazon Linux, Samuel develops Rust and Python-based systems that deals with CVE processing at AWS.\nHe also helps people learning packaging and starting to contributing to Debian.\n","description":"","id":"https://samueloph.dev/about/","title":"About"},"https://samueloph.dev/blog/":{"body":"","description":"","id":"https://samueloph.dev/blog/","title":""},"https://samueloph.dev/blog/hello-world/":{"body":"This is my very first post, just to make sure everything is working as expected.\nMade with Zola and the Abridge theme.\n","description":"","id":"https://samueloph.dev/blog/hello-world/","title":"Hello World"},"https://samueloph.dev/images/":{"body":"","description":"","id":"https://samueloph.dev/images/","title":""},"https://samueloph.dev/pages/":{"body":"","description":"","id":"https://samueloph.dev/pages/","title":""}},"docInfo":{"https://samueloph.dev/":{"body":0,"description":0,"title":0},"https://samueloph.dev/about/":{"body":94,"description":0,"title":0},"https://samueloph.dev/blog/":{"body":0,"description":0,"title":0},"https://samueloph.dev/blog/hello-world/":{"body":12,"description":0,"title":2},"https://samueloph.dev/images/":{"body":0,"description":0,"title":0},"https://samueloph.dev/pages/":{"body":0,"description":0,"title":0}},"length":6},"lang":"English"}